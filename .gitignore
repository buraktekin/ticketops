# ── Dependencies ───────────────────────────────────────────────────────────────
node_modules/

# ── Environment & secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging

# ── Playwright browser session (contains your login cookies) ──────────────────
storage/sessions/
storage/screenshots/
storage/state.json

# ── WhatsApp session (contains your WhatsApp auth token) ──────────────────────
.wwebjs_auth/
.wwebjs_cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/*.log
*.log

# ── targets.json (contains your artist URLs — optional to keep private) ───────
# Uncomment the line below if you don't want your targets public:
# targets.json

# ── OS & editor junk ──────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── pm2 ───────────────────────────────────────────────────────────────────────
.pm2/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
